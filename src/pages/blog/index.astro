---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import FloatingDecor from '../../components/FloatingDecor.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// Group posts by tag categories for the sidebar
const allTags = [...new Set(posts.flatMap(p => p.data.tags))];

// Estimate read time from content length
function getReadTime(body: string) {
  const words = body.split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 200));
}
---

<BaseLayout title="Blog — Kiwi Made Deli" description="Kyuhee Jo's blog — thoughts on tech, product, career, and building things that matter.">
  <Navigation />
  <FloatingDecor />

  <main class="blog-page">
    <div class="deli-container">
      <!-- AISLE SIDEBAR -->
      <aside class="aisle-sidebar">
        <div class="aisle-label">AISLE DIRECTORY</div>

        <a href="#all" class="sidebar-item active">
          <span class="aisle-number">00</span>
          ALL ITEMS ({posts.length})
        </a>
        {allTags.map((tag, i) => (
          <a href={`#${tag}`} class="sidebar-item" data-tag={tag}>
            <span class="aisle-number">{String(i + 1).padStart(2, '0')}</span>
            {tag.toUpperCase()}
          </a>
        ))}

        <div style="flex: 1;"></div>

        <div class="sidebar-special">
          <div class="special-tag">TODAY'S SPECIAL</div>
          HIRE ONE<br>GET ONE FREE
        </div>

        <a href="/" class="sidebar-back">
          &larr; BACK TO STORE
        </a>
      </aside>

      <!-- RECEIPT BOARD (MAIN) -->
      <div class="receipt-board">
        <div class="receipt-tear"></div>

        <!-- Receipt Header -->
        <header class="receipt-header">
          <div class="receipt-stamp">FRESH DAILY</div>
          <h1 class="receipt-logo">KIWI MADE DELI</h1>
          <div class="receipt-sub">EST. 2024 &bull; KYUHEE JO'S BLOG</div>
          <div class="receipt-address">123 DEVELOPER LANE &bull; PORTFOLIO CITY &bull; THE INTERNET</div>
          <div class="receipt-divider-fancy">
            <span class="divider-dot"></span>
            <span class="divider-dot"></span>
            <span class="divider-dot"></span>
          </div>
        </header>

        <!-- Order Info -->
        <div class="order-info">
          <div class="order-row">
            <span>ORDER #</span>
            <span>98-BLOG-{String(posts.length).padStart(3, '0')}</span>
          </div>
          <div class="order-row">
            <span>DATE</span>
            <span>{new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }).toUpperCase()}</span>
          </div>
          <div class="order-row">
            <span>CASHIER</span>
            <span>KYUHEE J.</span>
          </div>
        </div>

        <!-- Section Title -->
        <div class="menu-section-title">
          <span class="section-icon">&#9733;</span>
          FRESH POSTS
          <span class="section-icon">&#9733;</span>
        </div>

        <!-- Blog Posts -->
        <div class="menu-items" id="menu-items">
          {posts.map((post, index) => {
            const date = new Date(post.data.date);
            const dateStr = date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
            const readTime = getReadTime(post.body || '');
            return (
              <a href={`/blog/${post.id}`} class="menu-item" data-tags={post.data.tags.join(',')}>
                <div class="item-number">{String(index + 1).padStart(2, '0')}</div>
                <div class="item-main">
                  <div class="item-name-row">
                    <span class="item-name">{post.data.title}</span>
                    {index === 0 && <span class="new-badge">NEW!</span>}
                  </div>
                  <span class="item-flavor">{post.data.description}</span>
                  <div class="item-tags">
                    {post.data.tags.map((tag: string) => (
                      <span class="tag-chip">{tag}</span>
                    ))}
                  </div>
                  <div class="item-stats">
                    <span class="stat-date">{dateStr}</span>
                    <span class="stat-read">{readTime} MIN READ</span>
                    <span class="stat-fresh">GRADE: ORGANIC</span>
                  </div>
                </div>
                <div class="item-right">
                  <div class="item-price">$0.00</div>
                  <div class="item-arrow">&rarr;</div>
                </div>
              </a>
            );
          })}
        </div>

        <!-- Empty state -->
        <div class="empty-state" id="empty-state" style="display: none;">
          <div class="empty-icon">&#127821;</div>
          <p>NO ITEMS IN THIS AISLE</p>
          <p class="empty-sub">Check another aisle or browse all items</p>
        </div>

        <!-- Receipt Footer -->
        <footer class="receipt-footer">
          <div class="footer-divider"></div>
          <div class="total-row">
            <span>SUBTOTAL</span>
            <span>{posts.length} ITEMS</span>
          </div>
          <div class="total-row">
            <span>TAX</span>
            <span>$0.00</span>
          </div>
          <div class="total-row grand-total">
            <span>TOTAL DUE</span>
            <span>$0.00</span>
          </div>
          <div class="payment-line">
            PAYMENT: CURIOSITY<br>
            CHANGE DUE: KNOWLEDGE
          </div>
          <div class="barcode"></div>
          <div class="barcode-number">9 781234 567890</div>
          <div class="receipt-message">*** THANK YOU FOR READING ***</div>
          <div class="receipt-message small">SAVE YOUR RECEIPT FOR FUTURE REFERENCE</div>
          <div class="receipt-message small">RETURNS ACCEPTED: FEEDBACK ALWAYS WELCOME</div>
          <div class="receipt-tear-bottom"></div>
        </footer>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .blog-page {
    background: linear-gradient(180deg, #E87A35 0%, #D66C2B 100%);
    min-height: 100vh;
    padding: 100px 40px 60px;
    position: relative;
    z-index: 10;
  }

  .deli-container {
    max-width: 1300px;
    margin: 0 auto;
    display: flex;
    gap: 30px;
    align-items: flex-start;
  }

  /* ==================== SIDEBAR ==================== */
  .aisle-sidebar {
    width: 260px;
    flex-shrink: 0;
    background: var(--seed-black);
    border-radius: 12px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    border: 4px solid #444;
    position: sticky;
    top: 100px;
  }

  .aisle-label {
    color: var(--accent-yellow);
    font-family: var(--font-logo);
    font-size: 22px;
    border-bottom: 2px dashed #555;
    padding-bottom: 12px;
    margin-bottom: 8px;
    letter-spacing: 1px;
  }

  .sidebar-item {
    color: rgba(255,255,255,0.7);
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 13px;
    padding: 10px 12px;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s;
    text-transform: uppercase;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .sidebar-item:hover {
    background: rgba(255,255,255,0.08);
    color: #fff;
  }

  .sidebar-item.active {
    background: var(--kiwi-main);
    color: #fff;
  }

  .aisle-number {
    font-family: var(--font-data);
    font-size: 11px;
    font-weight: 900;
    background: rgba(255,255,255,0.15);
    padding: 2px 6px;
    border-radius: 3px;
    min-width: 24px;
    text-align: center;
  }

  .sidebar-item.active .aisle-number {
    background: rgba(255,255,255,0.3);
  }

  .sidebar-special {
    background: var(--accent-yellow);
    border: 3px solid #fff;
    padding: 14px;
    color: var(--seed-black);
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 800;
    text-align: center;
    border-radius: 8px;
    margin-top: 12px;
    line-height: 1.4;
  }

  .special-tag {
    font-family: var(--font-logo);
    font-size: 12px;
    background: var(--ink-red);
    color: #fff;
    display: inline-block;
    padding: 2px 8px;
    border-radius: 4px;
    margin-bottom: 6px;
  }

  .sidebar-back {
    display: block;
    text-align: center;
    color: rgba(255,255,255,0.5);
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
    padding: 12px;
    margin-top: 8px;
    border-top: 1px solid #444;
    transition: color 0.2s;
  }

  .sidebar-back:hover {
    color: var(--kiwi-light);
  }

  /* ==================== RECEIPT BOARD ==================== */
  .receipt-board {
    flex: 1;
    background-color: var(--pouch-bg);
    border-radius: 4px;
    box-shadow: 5px 15px 40px rgba(0,0,0,0.2), inset 0 0 100px rgba(0,0,0,0.03);
    padding: 60px 50px;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .receipt-tear {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 15px;
    background-image: radial-gradient(circle, transparent 70%, var(--bg-color) 70%);
    background-size: 30px 30px;
    background-position: 0 -15px;
  }

  /* ==================== HEADER ==================== */
  .receipt-header {
    text-align: center;
    border-bottom: 2px dashed var(--seed-black);
    padding-bottom: 28px;
    margin-bottom: 24px;
    position: relative;
  }

  .receipt-stamp {
    display: inline-block;
    font-family: var(--font-logo);
    font-size: 14px;
    color: var(--ink-red);
    border: 3px solid var(--ink-red);
    padding: 4px 16px;
    border-radius: 4px;
    transform: rotate(-5deg);
    margin-bottom: 12px;
    letter-spacing: 2px;
    opacity: 0.8;
  }

  .receipt-logo {
    font-family: var(--font-logo);
    font-size: 52px;
    color: var(--seed-black);
    letter-spacing: -1px;
    line-height: 1;
    margin-bottom: 8px;
  }

  .receipt-sub {
    font-family: var(--font-mono);
    font-weight: 800;
    font-size: 14px;
    text-transform: uppercase;
    color: #666;
  }

  .receipt-address {
    font-family: var(--font-mono);
    font-size: 11px;
    color: #999;
    margin-top: 6px;
    letter-spacing: 1px;
  }

  .receipt-divider-fancy {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 16px;
  }

  .divider-dot {
    width: 6px;
    height: 6px;
    background: var(--seed-black);
    border-radius: 50%;
  }

  /* ==================== ORDER INFO ==================== */
  .order-info {
    background: #fff;
    border: 2px solid var(--seed-black);
    padding: 14px 18px;
    margin-bottom: 28px;
    font-family: var(--font-mono);
    font-size: 13px;
  }

  .order-row {
    display: flex;
    justify-content: space-between;
    padding: 3px 0;
    border-bottom: 1px dotted #ddd;
  }

  .order-row:last-child {
    border-bottom: none;
  }

  .order-row span:first-child {
    font-weight: 800;
    color: #888;
  }

  .order-row span:last-child {
    font-weight: 700;
  }

  /* ==================== SECTION TITLE ==================== */
  .menu-section-title {
    font-family: var(--font-mono);
    font-weight: 800;
    font-size: 18px;
    margin-bottom: 24px;
    padding: 6px 14px;
    background: var(--seed-black);
    color: #fff;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    letter-spacing: 1px;
  }

  .section-icon {
    color: var(--accent-yellow);
    font-size: 14px;
  }

  /* ==================== MENU ITEMS ==================== */
  .menu-item {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 8px;
    padding: 16px;
    border-bottom: 1px dotted #ccc;
    border-radius: 6px;
    transition: all 0.2s;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .menu-item:hover {
    background: rgba(108, 166, 50, 0.08);
    border-bottom-color: var(--kiwi-main);
    transform: translateX(4px);
  }

  .menu-item:last-child {
    border-bottom: none;
  }

  .item-number {
    font-family: var(--font-mono);
    font-weight: 900;
    font-size: 28px;
    color: rgba(0,0,0,0.08);
    line-height: 1;
    min-width: 40px;
    padding-top: 2px;
  }

  .menu-item:hover .item-number {
    color: var(--kiwi-main);
  }

  .item-main {
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }

  .item-name-row {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .item-name {
    font-family: var(--font-mono);
    font-weight: 800;
    font-size: 17px;
    text-transform: uppercase;
    color: var(--seed-black);
    line-height: 1.3;
  }

  .new-badge {
    font-family: var(--font-logo);
    font-size: 11px;
    background: var(--ink-red);
    color: #fff;
    padding: 2px 8px;
    border-radius: 4px;
    animation: pulse 2s infinite;
  }

  .item-flavor {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink-red);
    font-style: italic;
    line-height: 1.4;
  }

  .item-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .tag-chip {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 800;
    text-transform: uppercase;
    background: rgba(108, 166, 50, 0.12);
    color: var(--kiwi-dark);
    padding: 3px 8px;
    border-radius: 3px;
    border: 1px solid rgba(108, 166, 50, 0.25);
  }

  .item-stats {
    display: flex;
    gap: 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: #999;
    text-transform: uppercase;
    margin-top: 2px;
  }

  .stat-date::before { content: '📅 '; }
  .stat-read::before { content: '⏱ '; }
  .stat-fresh::before { content: '🌿 '; }

  .item-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;
    min-width: 70px;
  }

  .item-price {
    font-family: var(--font-mono);
    font-weight: 800;
    font-size: 22px;
    white-space: nowrap;
    color: var(--seed-black);
  }

  .item-arrow {
    font-size: 20px;
    color: #ccc;
    transition: all 0.2s;
  }

  .menu-item:hover .item-arrow {
    color: var(--kiwi-main);
    transform: translateX(4px);
  }

  /* ==================== EMPTY STATE ==================== */
  .empty-state {
    text-align: center;
    padding: 60px 20px;
    font-family: var(--font-mono);
  }

  .empty-icon {
    font-size: 64px;
    margin-bottom: 16px;
  }

  .empty-state p {
    font-weight: 800;
    font-size: 18px;
    color: #999;
  }

  .empty-sub {
    font-size: 13px !important;
    font-weight: 400 !important;
    margin-top: 4px;
  }

  /* ==================== FOOTER ==================== */
  .receipt-footer {
    margin-top: 36px;
    text-align: center;
  }

  .footer-divider {
    border-top: 2px dashed var(--seed-black);
    margin-bottom: 24px;
  }

  .total-row {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 16px;
    font-weight: 700;
    padding: 4px 0;
    color: #888;
  }

  .grand-total {
    font-size: 24px;
    font-weight: 800;
    color: var(--seed-black);
    border-top: 3px solid var(--seed-black);
    border-bottom: 3px solid var(--seed-black);
    padding: 8px 0;
    margin-top: 4px;
    margin-bottom: 20px;
  }

  .payment-line {
    font-family: var(--font-mono);
    font-size: 12px;
    color: #999;
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .barcode {
    width: 300px;
    height: 60px;
    background: repeating-linear-gradient(
      90deg,
      #000 0px, #000 2px,
      transparent 2px, transparent 4px,
      #000 4px, #000 5px,
      transparent 5px, transparent 8px,
      #000 8px, #000 9px,
      transparent 9px, transparent 12px
    );
    margin: 0 auto 6px;
  }

  .barcode-number {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 4px;
    color: #666;
    margin-bottom: 16px;
  }

  .receipt-message {
    font-family: var(--font-mono);
    font-size: 13px;
    color: #888;
    margin-bottom: 4px;
  }

  .receipt-message.small {
    font-size: 10px;
    color: #bbb;
  }

  .receipt-tear-bottom {
    height: 15px;
    background-image: radial-gradient(circle, transparent 70%, var(--pouch-bg) 70%);
    background-size: 30px 30px;
    background-position: 0 0;
    margin: 24px -50px -60px;
  }

  /* ==================== ANIMATIONS ==================== */
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }

  /* ==================== MOBILE ==================== */
  @media (max-width: 900px) {
    .blog-page {
      padding: 80px 16px 40px;
    }

    .deli-container {
      flex-direction: column;
      gap: 20px;
    }

    .aisle-sidebar {
      width: 100%;
      position: static;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 8px;
      padding: 16px;
      border-radius: 8px;
    }

    .aisle-label {
      width: 100%;
      font-size: 18px;
      margin-bottom: 4px;
    }

    .sidebar-item {
      font-size: 11px;
      padding: 6px 10px;
    }

    .sidebar-special { display: none; }
    .sidebar-back {
      width: 100%;
      border-top: none;
      padding: 8px;
    }

    .receipt-board {
      padding: 40px 20px;
    }

    .receipt-logo {
      font-size: 32px;
    }

    .menu-item {
      padding: 12px 8px;
    }

    .item-number {
      display: none;
    }

    .item-name {
      font-size: 14px;
    }

    .item-price {
      font-size: 18px;
    }

    .item-stats {
      flex-wrap: wrap;
      gap: 8px;
    }

    .grand-total {
      font-size: 18px;
    }

    .barcode {
      width: 200px;
      height: 45px;
    }

    .receipt-tear-bottom {
      margin: 24px -20px -40px;
    }
  }
</style>

<script>
  // Tag filtering on sidebar
  const sidebarItems = document.querySelectorAll('.sidebar-item[data-tag]');
  const allItem = document.querySelector('.sidebar-item:not([data-tag])');
  const menuItems = document.querySelectorAll('.menu-item[data-tags]');
  const emptyState = document.getElementById('empty-state');
  const menuContainer = document.getElementById('menu-items');

  function filterByTag(tag: string | null) {
    // Update active state
    document.querySelectorAll('.sidebar-item').forEach(el => el.classList.remove('active'));

    let visibleCount = 0;

    menuItems.forEach((item) => {
      const el = item as HTMLElement;
      const tags = el.dataset.tags?.split(',') || [];
      if (!tag || tags.includes(tag)) {
        el.style.display = 'flex';
        visibleCount++;
      } else {
        el.style.display = 'none';
      }
    });

    if (emptyState) {
      (emptyState as HTMLElement).style.display = visibleCount === 0 ? 'block' : 'none';
    }
  }

  allItem?.addEventListener('click', (e) => {
    e.preventDefault();
    filterByTag(null);
    allItem.classList.add('active');
  });

  sidebarItems.forEach(item => {
    item.addEventListener('click', (e) => {
      e.preventDefault();
      const tag = (item as HTMLElement).dataset.tag || null;
      filterByTag(tag);
      item.classList.add('active');
    });
  });
</script>
</BaseLayout>
