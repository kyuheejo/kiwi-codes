  .panel-header { text-align: center; margin-bottom: 16px; }
  .company-name { font-family: var(--font-logo); color: var(--kiwi-main); font-size: 24px; margin-bottom: 4px; line-height: 1.1; }
  .company-logo { width: 24px; height: 24px; object-fit: contain; vertical-align: middle; margin-right: 6px; }
  .duration { font-family: var(--font-display); font-size: 13px; color: #7A7266; font-weight: 600; }
  .nl-compact { padding: 12px; }
