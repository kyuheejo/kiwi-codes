---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import FloatingDecor from '../components/FloatingDecor.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const jobs = [
  {
    company: 'TRILLION LABS',
    photo: '/images/experience/photos/trillion.jpg',
    logo: '/images/experience/logos/trillion.png',
    role: 'Founding GTM Lead',
    period: 'Nov 2025 — Present',
    impactLabel: 'Go-to-market',
    impactValue: '100%',
    rows: [
      { label: 'AI Strategy (Enterprise GTM)', value: '100%' },
      { label: 'Product-Led Growth', value: '95%' },
      { label: 'Market Research & Positioning', value: '90%' },
      { label: 'Cross-functional Leadership', value: '98%' },
    ],
    footnote: '* Building AI that solves problems. Contains no artificial preservatives.',
  },
  {
    company: 'PALANTIR',
    photo: '/images/experience/photos/palantir.jpeg',
    logo: '/images/experience/logos/palantir.png',
    role: 'Deployment Strategist',
    period: 'Jun — Nov 2025',
    impactLabel: 'AI transformation',
    impactValue: '95%',
    rows: [
      { label: 'Enterprise Software Deployment', value: '100%' },
      { label: 'Data Integration (Ontology)', value: '92%' },
      { label: 'Client Problem Solving', value: '95%' },
      { label: 'Technical Communication', value: '90%' },
    ],
    footnote: '* Actually solving problems for large enterprises with software.',
  },
  {
    company: 'MCKINSEY',
    photo: '/images/experience/photos/mckinsey.jpeg',
    logo: '/images/experience/logos/mckinsey.png',
    role: 'Business Analyst',
    period: 'Apr 2023 — Mar 2025',
    impactLabel: 'Strategy',
    impactValue: '100%',
    rows: [
      { label: 'AI & Digital Strategy', value: '98%' },
      { label: 'GenAI POC (20-30% productivity lift)', value: '95%' },
      { label: 'Due Diligence (Healthcare, A&D)', value: '90%' },
      { label: 'Data Analysis (Time Series)', value: '92%' },
    ],
    footnote: '* Hypothetically solving problems with slides. $22M+ impact delivered.',
  },
  {
    company: 'GOOGLE',
    photo: '/images/experience/photos/google.jpeg',
    logo: '/images/experience/logos/google.png',
    role: 'SWE Intern',
    period: 'May — Aug 2022',
    impactLabel: 'Engineering',
    impactValue: '90%',
    rows: [
      { label: 'End-to-End API Pipeline', value: '100%' },
      { label: 'ML-Based Highlight Algorithm', value: '95%' },
      { label: 'Google Cloud Platform', value: '85%' },
      { label: 'Production Feature Shipped', value: '100%' },
    ],
    footnote: '* Solving a problem for a large enterprise customer with a small feature.',
  },
  {
    company: 'LUNIT',
    photo: '/images/experience/photos/lunit.jpeg',
    logo: '/images/experience/logos/lunit.png',
    role: 'ML Intern',
    period: 'Dec 2021 — Jan 2022',
    impactLabel: 'Research',
    impactValue: '85%',
    rows: [
      { label: 'Breast Cancer Prediction (+10%)', value: '100%' },
      { label: 'Semi-Supervised Learning (0.1% labels)', value: '95%' },
      { label: 'Model Generalization Study', value: '88%' },
      { label: 'Research Presentation (40+ audience)', value: '80%' },
    ],
    footnote: '* Proactively created first-ever intern position in research dept.',
  },
  {
    company: 'JHU',
    photo: '/images/experience/photos/jhu.jpeg',
    logo: '/images/experience/logos/jhu.png',
    role: 'BS Computer Science',
    period: '2019 — 2023',
    impactLabel: 'Foundation',
    impactValue: '100%',
    rows: [
      { label: 'Computer Science (GPA 3.95)', value: '100%' },
      { label: 'Entrepreneurship & Management', value: '90%' },
      { label: 'Applied Math & Statistics', value: '85%' },
      { label: 'Teaching Assistant (5 courses)', value: '95%' },
    ],
    footnote: '* Percent Daily Values based on a diet of ramen and library sessions.',
  },
];

const projects = [
   {
    title: 'SLIDE STUDIO', flavor: 'Markdown Slides',
    screenshot: '/images/projects/slide-studio.png',
    badgeText: 'APP\n100%', badgeColor: 'var(--kiwi-light)',
    stack: [{ label: 'Type', value: 'Desktop App' }, { label: 'Stack', value: 'Tauri + JS' }, { label: 'Export', value: 'HTML / PPTX' }],
    description: 'Markdown to beautiful presentations — 11 themes, offline, export to HTML or PPTX.',
  },
  {
    title: 'TTT', flavor: 'Offline Translator',
    screenshot: '/images/projects/ttt.png',
    badgeText: 'AI\n100%', badgeColor: 'var(--accent-yellow)',
    stack: [{ label: 'Type', value: 'Desktop App' }, { label: 'Stack', value: 'Tauri + React' }, { label: 'Engine', value: 'llama.cpp' }],
    description: 'Offline translation app powered by on-device AI — no cloud, no API keys required.',
  },
  {
    title: 'SUPERMARK AI', flavor: 'GenAI Bookmarks',
    screenshot: '/images/projects/supermark-ai.png',
    badgeText: 'AI\n100%', badgeColor: 'var(--accent-yellow)',
    stack: [{ label: 'Type', value: 'Chrome Extension' }, { label: 'Role', value: 'PM' }, { label: 'Shipped', value: 'Jun 2023' }],
    description: 'ChatGPT-powered bookmarks — save websites & PDFs, then chat with them.',
  },
  {
    title: 'GUIDEDOG', flavor: 'ML for the Blind',
    screenshot: '/images/projects/guidedog.png',
    badgeText: 'ML\n100%', badgeColor: 'var(--kiwi-light)',
    stack: [{ label: 'Type', value: 'Mobile App' }, { label: 'Role', value: 'PM + Dev' }, { label: 'Award', value: 'HopHacks 1st' }],
    description: 'Voice-controlled app with object detection and image captioning for visually impaired users.',
  },
  {
    title: 'SPLIT.IT', flavor: 'Rideshare Pooling',
    screenshot: '/images/projects/split-it.png',
    badgeText: 'JS\n100%', badgeColor: 'var(--accent-yellow)',
    stack: [{ label: 'Type', value: 'Web App' }, { label: 'Role', value: 'Fullstack Dev' }, { label: 'Shipped', value: 'Jan 2022' }],
    description: 'Cost pooling platform for ridesharing — split fares, save money.',
  },
];

const videos = [
  { title: 'AI Video Creation Demo', description: 'Exploring the latest AI video generation tools and techniques.', date: '2024' },
  { title: 'Tech & Product Thoughts', description: 'Sharing insights on building products at the intersection of tech and business.', date: '2024' },
  { title: 'Startup Life in Korea', description: 'Behind the scenes of building at Trillion Labs and the Korean tech ecosystem.', date: '2025' },
];
---

<BaseLayout title="Kiwi Made — Kyuhee Jo">

  <!-- ============ LOADING SPLASH ============ -->
  <div id="splash" class="splash-overlay">
    <svg class="splash-bg-fruit" style="top: 10%; left: 10%;" width="120" height="120" viewBox="0 0 200 200">
      <circle cx="100" cy="100" r="80" fill="var(--kiwi-main)" />
      <circle cx="100" cy="100" r="30" fill="white" />
    </svg>
    <svg class="splash-bg-fruit" style="bottom: 15%; right: 10%;" width="150" height="150" viewBox="0 0 160 140">
      <path fill="var(--accent-yellow)" d="M150,70 C150,110 110,130 70,130 C20,130 10,90 10,50 C10,10 60,10 100,10 C140,10 150,30 150,70 Z" />
    </svg>
    <div class="splash-container">
      <div class="pouch-mini">
        <div class="straw"></div>
        <div class="logo-area">
          <div class="logo-circle"></div>
          <div class="pouch-text">KIWI<br/>MADE</div>
        </div>
        <div class="progress-wrapper">
          <div class="juice-bar-container">
            <div class="juice-fill"></div>
          </div>
        </div>
        <div class="vitamin-text">VITAMIN-RICH UI INCOMING</div>
      </div>
      <h1 class="loading-tagline">Freshly Squeezing<br/>Your Experience...</h1>
    </div>
  </div>

  <!-- ============ MAIN CONTENT ============ -->
  <div id="main-content" class="main-hidden">
    <Navigation />
    <FloatingDecor />

    <!-- ===== HERO ===== -->
    <section id="hero" class="hero-section">
      <div class="package-container">

        <!-- SOCIAL STICKERS (inside left edge) -->
        <div class="social-stickers">
          <a href="https://github.com/kyuheejo" target="_blank" rel="noopener" class="sticker sticker-github" aria-label="GitHub">
            <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
          <a href="https://x.com/kyuheejo" target="_blank" rel="noopener" class="sticker sticker-x" aria-label="X">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://linkedin.com/in/kyuheejo/" target="_blank" rel="noopener" class="sticker sticker-linkedin" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://www.youtube.com/@kpopreaction" target="_blank" rel="noopener" class="sticker sticker-youtube" aria-label="YouTube">
            <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>

        <!-- FRONT PANEL -->
        <section class="panel-front">
          <div class="hero-badges-container">
            <div class="hero-badge hero-badge-dev">100%<br/>DEV</div>
            <div class="hero-badge hero-badge-vegan">JHU<br/>'23</div>
          </div>

          <div class="portrait-brand">
            <span class="brand-kiwi">KIWI</span>
            <span class="brand-made">Kyuhee Jo</span>
          </div>

          <div class="portrait-photo">
            <img src="/images/kyuhee-profile-transparent.png" alt="Kyuhee Jo" />
          </div>

          <div class="flavor-profile">
            <h2 class="flavor-title">Ex-consultant<span>Coder &amp; CREATOR</span></h2>
            <p class="flavor-desc">Tech meets business — shipping products, advising enterprises, and creating content. Freshly squeezed.</p>
          </div>
        </section>

        <!-- BACK PANEL -->
        <section class="panel-back">
          <div class="ingredients-section">
            <div class="ingredients-header">Ingredients</div>
            <div class="ingredients-list">
              PYTHON, JAVASCRIPT, JAVA, GO, REACT, NODE.JS, SQL, FIGMA, PRODUCT STRATEGY, GTM PLAYBOOKS, AI STRATEGY, PREMIERE PRO.
              <br/>
              <span class="allergy-advice">ALLERGY ADVICE:</span> MAY CONTAIN BUGS (SQUASHED), EXCESSIVE AMBITION, AND TRACE AMOUNTS OF STARTUP ENERGY.
            </div>
          </div>

          <div class="nutrition-box">
            <div class="nutri-title">Nutrition Facts</div>
            <div class="nutri-row"><span>1 serving per portfolio</span></div>
            <div class="nutri-row bold-border">
              <strong>Serving size</strong>
              <strong>1 Kyuhee Jo</strong>
            </div>
            <div class="nutri-row medium-border" style="align-items: flex-end; padding-top: 10px;">
              <span>Amount per serving<br/><strong class="nutri-huge">Builder</strong></span>
              <strong class="nutri-huge">100%</strong>
            </div>
            <div class="daily-value-text">% Daily Value*</div>
            <div class="nutri-row">
              <strong>Dev (Python, JS, Java, Go)</strong>
              <span>80%</span>
            </div>
            <div class="nutri-row indent">
              <span>React, Node.js, SQL</span>
              <span>75%</span>
            </div>
            <div class="nutri-row">
              <strong>GTM &amp; Product Strategy</strong>
              <span>90%</span>
            </div>
            <div class="nutri-row">
              <strong>Consulting &amp; Strategy</strong>
              <span>85%</span>
            </div>
            <div class="nutri-row bold-border">
              <strong>Creator (Figma, Premiere)</strong>
              <span>75%</span>
            </div>
            <div style="font-size: 9px; margin-top: 8px; color: #555; line-height: 1.3; font-weight: 600;">
              * Based on years of caffeinated productivity. Your daily values may be higher or lower depending on sprint planning.
            </div>
          </div>

          <div class="back-footer">
            <div class="barcode-area">
              <div class="hero-barcode">
                <div class="bar bar-1"></div><div class="bar bar-2"></div><div class="bar bar-3"></div>
                <div class="bar bar-4"></div><div class="bar bar-5"></div><div class="bar bar-6"></div>
                <div class="bar bar-2"></div><div class="bar bar-1"></div><div class="bar bar-4"></div>
                <div class="bar bar-7"></div><div class="bar bar-8"></div><div class="bar bar-9"></div>
                <div class="bar bar-10"></div><div class="bar bar-2"></div><div class="bar bar-5"></div>
                <div class="bar bar-1"></div><div class="bar bar-12"></div><div class="bar bar-3"></div>
              </div>
              <div class="barcode-text">08 920 481 293</div>
            </div>
            <div class="cta-wrapper">
              <a href="mailto:kyuhee0622@gmail.com" class="btn-hire">CONTACT KYUHEE</a>
              <div class="hero-net-weight">Net Wt. GPA 3.95 ℮</div>
            </div>
          </div>
        </section>

      </div>
    </section>

    <!-- ===== EXPERIENCE ===== -->
    <section id="experience" class="section-experience">
      <div class="section-inner">
        <h2 class="section-title reveal">EXPERIENCE</h2>
        <div class="timeline-scroll">
          {jobs.map((job) => (
            <div class="serving-panel reveal-scale">
              <div class="panel-header">
                <h3 class="company-name">
                  <img src={job.logo} alt={job.company} class="company-logo" />
                  {job.company}
                </h3>
                <p class="duration">{job.period}</p>
              </div>
              <div class="photo-label">
                <div class="photo-label-header">Photo from this era</div>
                <div class="photo-frame">
                  <img src={job.photo} alt={`Kyuhee at ${job.company}`} />
                </div>
              </div>
              <div class="nutrition-label nl-compact">
                <div class="nl-header">{job.company === 'JHU' ? 'Academic Facts' : 'Job Role Facts'}</div>
                <div class="nl-row"><span>1 position per career</span></div>
                <div class="nl-row thick"><b>Serving size</b> <b>{job.role}</b></div>
                <div class="nl-row thick">
                  <span>Impact per year<br/><b style="font-size: 18px;">{job.impactLabel}</b></span>
                  <b style="font-size: 18px;">{job.impactValue}</b>
                </div>
                <div class="nl-row" style="justify-content: flex-end;"><b>% Daily Contribution*</b></div>
                {job.rows.map((row) => (
                  <div class="nl-row"><span><b>{row.label}</b></span><span>{row.value}</span></div>
                ))}
                <div style="font-size: 8px; margin-top: 8px; line-height: 1.1; color: #666;">{job.footnote}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== PROJECTS ===== -->
    <section id="projects" class="section-projects">
      <div class="section-inner">
        <div class="header-strip reveal">
          <span>SHIPPED PRODUCTS</span>
          <span class="header-strip-sub">FRESHLY SQUEEZED SINCE 2021</span>
        </div>

        <div class="shelf reveal">
          {projects.slice(0, 3).map((p) => (
            <div class="pouch reveal-scale">
              <div class="tech-badge-pouch" style={`background: ${p.badgeColor}`}>
                {p.badgeText.split('\n').map((line, i) => i === 0 ? line : <><br/>{line}</>)}
              </div>
              <div class="project-screenshot">
                <img src={p.screenshot} alt={`${p.title} screenshot`} />
              </div>
              <div class="pouch-header">
                <div class="flavor-badge">{p.flavor}</div>
                <h3 class="project-title">{p.title}</h3>
              </div>
              <p class="project-desc">{p.description}</p>
              <div class="nutrition-mini">
                <div class="nutrition-mini-header">App Stack Facts</div>
                {p.stack.map((s) => (
                  <div class="nl-row"><b>{s.label}</b> <span>{s.value}</span></div>
                ))}
              </div>
              <span class="recipe-btn">VIEW RECIPE</span>
            </div>
          ))}
          <div class="price-tag-rail">
            <div class="price-tag">PRICED TO HIRE: $0.00</div>
            <div class="price-tag">OPEN SOURCE FREE</div>
            <div class="price-tag">HACKATHON WINNER</div>
          </div>
        </div>

        <div class="shelf shelf-narrow reveal">
          {projects.slice(3).map((p) => (
            <div class="pouch reveal-scale">
              <div class="tech-badge-pouch" style={`background: ${p.badgeColor}`}>
                {p.badgeText.split('\n').map((line, i) => i === 0 ? line : <><br/>{line}</>)}
              </div>
              <div class="project-screenshot">
                <img src={p.screenshot} alt={`${p.title} screenshot`} />
              </div>
              <div class="pouch-header">
                <div class="flavor-badge">{p.flavor}</div>
                <h3 class="project-title">{p.title}</h3>
              </div>
              <p class="project-desc">{p.description}</p>
              <div class="nutrition-mini">
                <div class="nutrition-mini-header">App Stack Facts</div>
                {p.stack.map((s) => (
                  <div class="nl-row"><b>{s.label}</b> <span>{s.value}</span></div>
                ))}
              </div>
              <span class="recipe-btn">VIEW RECIPE</span>
            </div>
          ))}
          <div class="price-tag-rail">
            <div class="price-tag">NEW FLAVOR!</div>
            <div class="price-tag">PREMIUM QUALITY</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== BLOG ===== -->
    <section id="blog" class="section-blog">
      <div class="section-inner">
        <div class="receipt-board reveal">
          <div class="receipt-tear"></div>
          <header class="receipt-header">
            <h2 class="receipt-logo">KIWI MADE DELI</h2>
            <div class="receipt-sub">EST. 2024 &bull; KYUHEE JO'S BLOG</div>
          </header>

          <div class="menu-section-title">FRESH POSTS</div>

          {posts.map((post) => {
            const date = new Date(post.data.date);
            const dateStr = date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
            return (
              <a href={`/blog/${post.id}`} class="menu-item reveal-child">
                <div class="item-main">
                  <span class="item-name">{post.data.title}</span>
                  <span class="item-flavor">{post.data.description}</span>
                  <div class="item-stats">
                    <span>{dateStr}</span>
                    <span>{post.data.tags.join(', ').toUpperCase()}</span>
                  </div>
                </div>
                <div class="item-price">$0.00</div>
              </a>
            );
          })}

          <footer class="receipt-footer">
            <div class="total-row">
              <span>TOTAL POSTS</span>
              <span>{posts.length}</span>
            </div>
            <div class="barcode"></div>
            <div style="font-family: var(--font-mono); font-size: 11px; margin-top: 10px; color: #888;">*** THANK YOU FOR READING ***</div>
            <a href="/blog" class="see-more-btn">
              SEE FULL MENU &rarr;
            </a>
          </footer>
        </div>
      </div>
    </section>

    <!-- ===== VIDEOS ===== -->
    <section id="videos" class="section-videos">
      <div class="section-inner">
        <div class="header-strip reveal">
          <span>Video creation</span>
          <span class="header-strip-sub">FRESHLY BLENDED</span>
        </div>

        <div class="cooler-label reveal">
          <div class="cooler-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor">
              <path d="M21 3H3c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h5v2h8v-2h5c1.1 0 1.99-.9 1.99-2L23 5c0-1.1-.9-2-2-2zm0 14H3V5h18v12zm-5-6l-7 4V7l7 4z"/>
            </svg>
          </div>
          <h3 class="cooler-title">BEVERAGE COOLER</h3>
          <p>Video content — AI experiments, tech talks, and creative projects</p>
        </div>

        <div class="video-grid">
          {videos.map((video) => (
            <a href="https://www.youtube.com/@kpopreaction" target="_blank" rel="noopener" class="juice-box reveal-scale">
              <div class="juice-box-top">
                <div class="play-circle">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>
                </div>
                <div class="juice-box-straw"></div>
              </div>
              <div class="juice-box-label">
                <h4 class="juice-box-title">{video.title}</h4>
                <p class="juice-box-desc">{video.description}</p>
                <div class="juice-box-meta">
                  <span>{video.date}</span>
                  <span class="juice-box-badge">YOUTUBE</span>
                </div>
              </div>
            </a>
          ))}
