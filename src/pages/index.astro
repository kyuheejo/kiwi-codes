  .receipt-tear { position: absolute; top: 0; left: 0; right: 0; height: 15px; background-image: radial-gradient(circle, transparent 70%, var(--bg-color) 70%); background-size: 30px 30px; background-position: 0 -15px; }
  .receipt-header { text-align: center; border-bottom: 2px dashed var(--seed-black); padding-bottom: 24px; margin-bottom: 30px; }
  .receipt-logo { font-family: var(--font-logo); font-size: 38px; color: var(--seed-black); }
  .receipt-sub { font-family: var(--font-mono); font-weight: 800; font-size: 13px; text-transform: uppercase; margin-top: 5px; }
  .menu-section-title { font-family: var(--font-mono); font-weight: 800; font-size: 18px; margin-bottom: 20px; padding: 4px 10px; background: var(--seed-black); color: #fff; display: inline-block; }
  .menu-item { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 12px; padding: 10px; border-bottom: 1px dotted #ccc; border-radius: 4px; transition: background 0.2s; }
  .menu-item:hover { background: rgba(108, 166, 50, 0.1); }
