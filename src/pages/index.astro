  .flavor-badge { font-family: var(--font-logo); color: var(--bg-color); font-size: 16px; text-transform: uppercase; }
  .project-title { font-family: var(--font-logo); color: var(--seed-black); font-size: 22px; line-height: 1; }
  .project-desc { font-family: var(--font-data); font-size: 12px; color: #666; line-height: 1.4; text-align: center; }
  .nutrition-mini { background: #fff; border: 2px solid var(--seed-black); padding: 8px; font-family: var(--font-data); font-size: 11px; }
  .nutrition-mini-header { font-weight: 900; border-bottom: 3px solid var(--seed-black); margin-bottom: 4px; }
