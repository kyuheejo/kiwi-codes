            const date = new Date(post.data.date);
            const dateStr = date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
            return (
              <a href={`/blog/${post.id}`} class="menu-item reveal-child">
                <div class="item-main">
                  <span class="item-name">{post.data.title}</span>
                  <span class="item-flavor">{post.data.description}</span>
                  <div class="item-stats">
                    <span>{dateStr}</span>
                    <span>{post.data.tags.join(', ').toUpperCase()}</span>
                  </div>
                </div>
                <div class="item-price">$0.00</div>
              </a>
            );
          })}

          <footer class="receipt-footer">
            <div class="total-row">
              <span>TOTAL POSTS</span>
              <span>{posts.length}</span>
            </div>
            <div class="barcode"></div>
            <div style="font-family: var(--font-mono); font-size: 11px; margin-top: 10px; color: #888;">*** THANK YOU FOR READING ***</div>
            <a href="/blog" class="see-more-btn">
              SEE FULL MENU &rarr;
            </a>
          </footer>
        </div>
      </div>
    </section>

    <!-- ===== VIDEOS / DELI TV ===== -->
    <section id="videos" class="section-videos">
      <div class="section-inner">

        <div class="header-strip reveal">
          <span>Deli TV</span>
          <span class="header-strip-sub">NOW SHOWING</span>
        </div>

        <div class="deli-tv-wrapper reveal-scale">

          <!-- The TV area (TV + shelf + stickers) -->
          <div class="tv-area">
            <!-- Wall stickers -->
            <div class="wall-sticker sticker-1" aria-hidden="true">FRESH!</div>
            <div class="wall-sticker sticker-2" aria-hidden="true">NEW</div>

            <!-- The TV Set -->
            <div class="tv-set">
              <!-- Antenna -->
              <div class="tv-antenna">
                <div class="antenna-rod left"></div>
                <div class="antenna-rod right"></div>
                <div class="antenna-base"></div>
              </div>
              <!-- CRT Housing — chunky beige/cream plastic -->
              <div class="tv-housing">
                <!-- Sticker on TV housing, above the screen -->
                <div class="tv-sticker" aria-hidden="true">KIWI MART PROPERTY<br/>DO NOT TOUCH!</div>
                <!-- Screen area -->
                <div class="tv-screen-wrap">
                  <div class="tv-screen" id="tv-screen" data-videos={JSON.stringify(videos.map(v => v.videoId))}>
                    <canvas id="tv-static-canvas"></canvas>
                    <div class="tv-scanlines"></div>
                    <div class="tv-glow"></div>
                    <div class="tv-channel-display" id="tv-channel-display">CH 01</div>
                    <!-- Single YouTube iframe — src swapped on channel change -->
                    <iframe
                      id="tv-iframe"
                      class="tv-iframe"
                      src=""
                      data-src={`https://www.youtube.com/embed/${videos[0].videoId}?rel=0&modestbranding=1&autoplay=1&mute=1`}
                      title={videos[0].title}
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                      allowfullscreen
                      loading="lazy"
                    ></iframe>
                  </div>
                  <div class="tv-reflection"></div>
                </div>
                <!-- Bottom strip with brand + knobs + volume dial -->
                <div class="tv-bottom-strip">
                  <span class="tv-brand-name">KIWI</span>
                  <div class="tv-knobs">
                    <div class="tv-knob"></div>
                    <div class="tv-knob"></div>
                  </div>
                  <div class="tv-volume-group">
                    <span class="tv-volume-label">VOL</span>
                    <button class="tv-volume-dial muted" id="tv-volume-dial" aria-label="Toggle sound" title="Click to toggle sound">
                      <div class="dial-notch"></div>
                    </button>
                  </div>
                </div>
              </div>
            </div>

            <!-- TV Stand: shelf + cabinet -->
            <div class="tv-stand">
              <div class="tv-stand-shelf">
                <div class="shelf-price-tag">FREE VIEWING</div>
                <div class="shelf-price-tag tag-yellow">ORGANIC CONTENT</div>
              </div>
              <div class="tv-stand-cabinet">
                <div class="cabinet-door door-left">
                  <div class="cabinet-panel">
                    <div class="cabinet-knob"></div>
                  </div>
                </div>
                <div class="cabinet-divider"></div>
                <div class="cabinet-door door-right">
                  <div class="cabinet-panel">
                    <div class="cabinet-knob"></div>
                  </div>
                </div>
                <!-- Stickers on the cabinet -->
                <div class="cab-sticker cab-sticker-organic" aria-hidden="true">ORGANIC</div>
                <div class="cab-sticker cab-sticker-local" aria-hidden="true">LOCAL<br/>FAVORITE</div>
                <div class="cab-coupon" aria-hidden="true">
                  <span class="coupon-off">50% OFF</span>
                  <span class="coupon-detail">BINGE WATCHING</span>
                  <div class="coupon-dashed"></div>
                  <span class="coupon-code">CODE: KIWI50</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Remote / Channel Guide — styled as a clipboard or receipt -->
          <div class="remote-control">
            <div class="remote-body">
              <!-- Clipboard clip -->
              <div class="clipboard-clip"></div>
              <div class="remote-header">
                <div class="remote-title">CHANNEL GUIDE</div>
                <div class="remote-sub">~ pick your flavor ~</div>
              </div>
              <!-- Current channel display -->
              <div class="remote-now-playing">
                <span class="now-label">NOW PLAYING</span>
                <span class="now-ch" id="remote-ch-num">CH 01</span>
              </div>
              <!-- Channel Buttons as menu items -->
              <div class="remote-channels">
                {videos.map((video, i) => (
                  <button
                    class={`ch-btn ${i === 0 ? 'active' : ''}`}
                    data-channel={i}
                    data-ch={video.ch}
                  >
                    <span class="ch-btn-num">CH {video.ch}</span>
                    <span class="ch-btn-dots"></span>
                    <span class="ch-btn-title">{video.title}</span>
                  </button>
                ))}
              </div>
              <!-- Channel nav arrows -->
              <div class="remote-nav">
                <button class="ch-nav-btn" id="ch-up" aria-label="Previous channel">
                  ▲ PREV
                </button>
                <button class="ch-nav-btn" id="ch-down" aria-label="Next channel">
                  NEXT ▼
                </button>
              </div>
              <!-- Footer -->
              <div class="remote-footer">
                <a href="https://www.youtube.com/@kpopreaction" target="_blank" rel="noopener" class="remote-yt-btn">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0C.488 3.45.029 5.804 0 12c.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0C23.512 20.55 23.971 18.196 24 12c-.029-6.185-.484-8.549-4.385-8.816zM9 16V8l8 4-8 4z"/></svg>
                  VISIT FULL CHANNEL
                </a>
              </div>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ===== GUESTBOOK / DELI COUNTER ===== -->
    <section id="guestbook" class="section-guestbook">
      <div class="section-inner">

        <div class="header-strip reveal">
          <span>Order Rack</span>
          <span class="header-strip-sub">Visitor Notes</span>
        </div>

        <!-- Control Desk: dispenser | LED | form -->
        <div class="gb-control-desk reveal">

          <!-- Ticket Dispenser (hidden on mobile) -->
          <div class="gb-dispenser">
            <div class="gb-dispenser-cap"></div>
            <div class="gb-dispenser-label">Order Rack</div>
            <div class="gb-dispenser-slot"></div>
            <div class="gb-dispenser-stub" id="dispenser-next-num">043</div>
          </div>

          <!-- LED Panel -->
          <div class="gb-led-panel">
            <div class="gb-led-label">Now Serving</div>
            <div class="gb-led-text" id="now-serving-num">001</div>
          </div>

          <!-- Order Form -->
          <div class="gb-form-wrapper">
            <div class="gb-order-form">
              <div class="gb-order-form-inner">
                <div class="gb-form-header">Order Slip</div>
                <form id="guestbook-form" class="ticket-form">
                  <div class="gb-form-row">
                    <label class="gb-form-label">Name</label>
                    <input type="text" name="name" class="gb-form-input" maxlength="30" required placeholder="Write your name here..." autocomplete="off" />
                  </div>
                  <div class="gb-form-row">
                    <label class="gb-form-label">Message</label>
                    <textarea name="message" class="gb-form-input" rows="2" maxlength="200" required placeholder="Leave a message for the deli..."></textarea>
                  </div>
                  <div class="gb-char-count"><span id="char-count">0</span>/200</div>
                  <button type="submit" class="gb-submit-btn" id="gb-submit-btn">Submit Order →</button>
                  <div id="form-status" class="form-status"></div>
                </form>
              </div>
            </div>
          </div>
        </div>

        <!-- Ticket Rack System -->
        <div class="gb-rack-system reveal-scale" data-promos={JSON.stringify(promos)}>
          <div class="gb-rail-container">
            <div class="gb-metal-rail">
              <div class="gb-rail-groove"></div>
            </div>
          </div>
          <div class="gb-tickets-track" id="ticket-board">
            <!-- Tickets rendered by JS -->
            <div class="gb-ticket-sentinel" id="ticket-sentinel"></div>
          </div>
        </div>

      </div>
    </section>

    <!-- ===== FOOTER ===== -->
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-logo">KIWI MADE</div>
        <p>Kyuhee Jo — Coder, Creator, Consultant</p>
        <div class="footer-links">
          <a href="mailto:kyuhee0622@gmail.com">Email</a>
          <a href="https://linkedin.com/in/kyuheejo/" target="_blank" rel="noopener">LinkedIn</a>
          <a href="https://github.com/kyuheejo" target="_blank" rel="noopener">GitHub</a>
          <a href="https://www.youtube.com/@kpopreaction" target="_blank" rel="noopener">YouTube</a>
        </div>
        <p class="footer-copy">Freshly squeezed with Astro. No artificial preservatives.</p>
      </div>
    </footer>
  </div>
</BaseLayout>

<style is:global>
  /* ==================== SPLASH ==================== */
  .splash-overlay {
    position: fixed;
    inset: 0;
    background-color: var(--bg-color);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 200;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }
  .splash-overlay.hidden { opacity: 0; visibility: hidden; pointer-events: none; }
  .splash-bg-fruit { position: absolute; z-index: 1; opacity: 0.3; animation: float 10s infinite ease-in-out; }
  .splash-container { position: relative; display: flex; flex-direction: column; align-items: center; z-index: 10; }
  .pouch-mini {
    width: 400px; max-width: 90vw; background-color: var(--pouch-bg); border-radius: 24px;
    padding: 30px; box-shadow: 0 20px 40px rgba(0,0,0,0.1); position: relative;
    animation: squeeze 1s ease-in-out infinite; transform-origin: center; border: 4px solid var(--seed-black);
  }
  .straw {
    position: absolute; top: -50px; right: 60px; width: 25px; height: 80px;
    background: repeating-linear-gradient(45deg, #fff, #fff 10px, var(--bg-color) 10px, var(--bg-color) 20px);
    border: 4px solid var(--seed-black); border-radius: 5px; transform: rotate(15deg); z-index: -1;
  }
  .logo-area { display: flex; flex-direction: column; align-items: center; margin-bottom: 20px; }
  .logo-circle {
    width: 120px; height: 120px; background-color: var(--kiwi-main); border-radius: 50%;
    display: flex; justify-content: center; align-items: center; margin-bottom: 10px;
    border: 3px solid var(--kiwi-dark); position: relative; overflow: hidden;
  }
  .logo-circle::after { content: ''; position: absolute; width: 40px; height: 40px; background: #F4EBE1; border-radius: 50%; }
  .pouch-text { font-family: var(--font-logo); color: var(--seed-black); font-size: 32px; text-align: center; line-height: 0.9; }
  .progress-wrapper { width: 100%; margin-top: 30px; }
  .juice-bar-container { width: 100%; height: 40px; background: #fff; border: 4px solid var(--seed-black); border-radius: 20px; overflow: hidden; }
  .juice-fill { height: 100%; width: 0%; background-color: var(--kiwi-light); border-right: 4px solid var(--kiwi-dark); animation: fillJuice 1.75s ease-out forwards; position: relative; }
  .juice-fill::before { content: ''; position: absolute; inset: 0; background-image: radial-gradient(circle, rgba(255,255,255,0.4) 20%, transparent 20%); background-size: 15px 15px; animation: moveBubbles 1s linear infinite; }
  .vitamin-text { margin-top: 15px; text-align: center; font-family: var(--font-data); font-weight: 800; font-size: 12px; color: var(--kiwi-dark); }
  .loading-tagline { margin-top: 24px; color: white; font-family: var(--font-logo); font-size: 22px; text-shadow: 2px 2px 0px var(--seed-black); letter-spacing: 1px; animation: pulse 0.75s ease-in-out infinite; text-align: center; }

  /* ==================== LAYOUT ==================== */
  .main-hidden { opacity: 0; }
  .main-visible { opacity: 1; transition: opacity 0.4s ease; }

  /* ==================== HERO ENTRANCE ANIMATIONS ==================== */
  .package-container {
    opacity: 0;
    transform: scale(0.85) rotate(-2deg);
    transition: opacity 0.6s cubic-bezier(0.34, 1.56, 0.64, 1),
                transform 0.7s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .main-visible .package-container {
    opacity: 1;
    transform: scale(1) rotate(0deg);
    transition-delay: 0.2s;
  }

  .panel-front {
    opacity: 0;
    transform: translateX(-40px);
    transition: opacity 0.5s ease, transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .main-visible .panel-front {
    opacity: 1;
    transform: translateX(0);
    transition-delay: 0.5s;
  }

  .panel-back {
    opacity: 0;
    transform: translateX(40px);
    transition: opacity 0.5s ease, transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .main-visible .panel-back {
    opacity: 1;
    transform: translateX(0);
    transition-delay: 0.6s;
  }

  .hero-badge {
    opacity: 0;
    transform: scale(0) rotate(-20deg);
    transition: opacity 0.3s ease, transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .main-visible .hero-badge-dev {
    opacity: 1;
    transform: scale(1) rotate(-10deg);
    transition-delay: 0.9s;
  }
  .main-visible .hero-badge-vegan {
    opacity: 1;
    transform: scale(1) rotate(8deg);
    transition-delay: 1.05s;
  }

  .portrait-brand {
    opacity: 0;
    transform: translateY(-20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .main-visible .portrait-brand {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.7s;
  }

  .portrait-photo {
    opacity: 0;
    transform: translateY(30px) scale(0.9);
    transition: opacity 0.5s ease, transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .main-visible .portrait-photo {
    opacity: 1;
    transform: translateY(0) scale(1);
    transition-delay: 0.8s;
  }

  .flavor-profile {
    opacity: 0;
    transform: rotate(-6deg) scale(0.8);
    transition: opacity 0.4s ease, transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .main-visible .flavor-profile {
    opacity: 1;
    transform: rotate(-2deg) translateY(-7px) scale(1);
    transition-delay: 1s;
  }

  .ingredients-section {
    opacity: 0;
    transform: translateY(15px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .main-visible .ingredients-section {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.8s;
  }

  .nutrition-box {
    opacity: 0;
    transform: translateY(15px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .main-visible .nutrition-box {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.95s;
  }

  .back-footer {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .main-visible .back-footer {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 1.1s;
  }

  /* Social sticker pop-in */
  .sticker {
    opacity: 0;
    transform: scale(0) rotate(-30deg);
    transition: opacity 0.3s ease, transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .main-visible .sticker-github {
    opacity: 1;
    transform: scale(1) rotate(-6deg);
    transition-delay: 1.2s;
  }
  .main-visible .sticker-x {
    opacity: 1;
    transform: scale(1) rotate(4deg);
    transition-delay: 1.35s;
  }
  .main-visible .sticker-linkedin {
    opacity: 1;
    transform: scale(1) rotate(-3deg);
    transition-delay: 1.5s;
  }
  .main-visible .sticker-youtube {
    opacity: 1;
    transform: scale(1) rotate(5deg);
    transition-delay: 1.65s;
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
  }

  /* Section title shared */
  .section-title {
    font-family: var(--font-logo);
    color: white;
    font-size: 48px;
    text-shadow: 3px 3px 0 var(--seed-black);
    margin-bottom: 8px;
  }
  .section-subtitle {
    font-family: var(--font-data);
    font-size: 14px;
    color: rgba(255,255,255,0.7);
    margin-bottom: 30px;
  }

  .header-strip {
    background-color: var(--seed-black); color: #fff; padding: 15px 40px;
    font-family: var(--font-logo); font-size: 28px; display: flex;
    justify-content: space-between; align-items: center; border-radius: 8px;
    margin-bottom: 50px; box-shadow: 0 10px 20px rgba(0,0,0,0.2);
  }
  .header-strip-sub { font-size: 16px; }

  /* ==================== HERO ==================== */
  .hero-section {
    display: flex; justify-content: center; align-items: flex-start;
    min-height: 100vh; padding: 100px 40px 60px; position: relative; z-index: 10;
    scroll-margin-top: 60px;
  }
  .package-container {
    position: relative; display: flex; width: 1100px; max-width: 100%;
    height: 690px;
    background-color: var(--pouch-bg); border-radius: 32px;
    border: 4px solid var(--seed-black);
    box-shadow: inset 0 0 40px rgba(0,0,0,0.05), 16px 16px 0px rgba(42,31,26,0.15);
    overflow: hidden;
  }

  /* Social stickers — inside package, aligned with DEV badge */
  .social-stickers {
    position: absolute; left: 40px; top: 46%; transform: translateY(-50%);
    display: flex; flex-direction: column; gap: 10px; z-index: 20;
  }
  .sticker {
    width: 46px; height: 46px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    border: 3px solid var(--seed-black);
    box-shadow: 4px 4px 0px rgba(0,0,0,0.2);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.2s ease;
    cursor: pointer; text-decoration: none;
  }
  .sticker:hover {
    box-shadow: 2px 2px 0px rgba(0,0,0,0.2);
  }
  .sticker-github { background-color: #24292e; color: #fff; }
  .sticker-github:hover { transform: scale(1.15) rotate(0deg) !important; }
  .sticker-x { background-color: #000; color: #fff; }
  .sticker-x:hover { transform: scale(1.15) rotate(0deg) !important; }
  .sticker-linkedin { background-color: #0A66C2; color: #fff; }
  .sticker-linkedin:hover { transform: scale(1.15) rotate(0deg) !important; }
  .sticker-youtube { background-color: #FF0000; color: #fff; }
  .sticker-youtube:hover { transform: scale(1.15) rotate(0deg) !important; }

  /* Front panel (green left side) */
  .panel-front {
    flex: 1.1; background-color: var(--kiwi-main); padding: 30px 40px;
    display: flex; flex-direction: column; align-items: center; justify-content: space-between;
    position: relative; border-right: 4px dashed rgba(42,31,26,0.3);
  }
  .panel-front::before, .panel-front::after {
    content: ''; position: absolute; right: -14px; width: 24px; height: 24px;
    background-color: var(--bg-color); border: 4px solid var(--seed-black);
    border-radius: 50%; z-index: 10;
  }
  .panel-front::before { top: -14px; }
  .panel-front::after { bottom: -14px; }

  .hero-badges-container { width: 100%; display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: -20px; }
  .hero-badge {
    width: 80px; height: 80px; border-radius: 50%; display: flex; justify-content: center;
    align-items: center; font-family: var(--font-display); font-weight: 700; font-size: 16px;
    line-height: 1.1; text-align: center; border: 4px solid var(--seed-black);
    box-shadow: 4px 4px 0px rgba(0,0,0,0.2); transition: transform 0.2s ease;
  }
  .hero-badge:hover { transform: scale(1.05) rotate(5deg); }
  .hero-badge-dev { background-color: var(--kiwi-light); color: var(--seed-black); transform: rotate(-10deg); }
  .hero-badge-vegan { background-color: #fff; color: var(--kiwi-main); transform: rotate(8deg); }

  /* Portrait brand text above medallion */
  .portrait-brand {
    display: flex; flex-direction: column; align-items: center;
    line-height: 0.85;
  }
  .brand-kiwi {
    font-family: var(--font-logo); font-size: 52px; color: var(--pouch-bg);
    text-shadow: 2px 2px 0px rgba(0,0,0,0.2);
  }
  .brand-made {
    font-family: var(--font-logo); font-size: 34px; color: var(--bg-color);
    text-shadow: 1px 1px 0px rgba(0,0,0,0.2);
  }

  /* Portrait photo */
  .portrait-photo {
    width: 300px; height: 300px;
    display: flex; align-items: flex-end; justify-content: center;
    filter: drop-shadow(0px 8px 16px rgba(0,0,0,0.2));
  }
  .portrait-photo img {
    width: 100%; height: 100%; object-fit: contain; display: block;
  }

  .flavor-profile {
    text-align: center; background-color: var(--pouch-bg); padding: 16px 32px;
    border-radius: 20px; border: 4px solid var(--seed-black); transform: rotate(-2deg) translateY(-7px);
    box-shadow: 6px 6px 0px rgba(0,0,0,0.2);
  }
  .flavor-title {
    font-family: var(--font-logo); font-size: 28px; line-height: 1.2;
    color: var(--bg-color); margin-bottom: 8px;
  }
  .flavor-title span { color: var(--seed-black); font-size: 38px; display: block; }
  .flavor-desc {
    font-family: var(--font-display); font-weight: 600; font-size: 15px;
    color: var(--kiwi-dark); max-width: 340px;
  }

  /* Back panel (right side) */
  .panel-back {
    flex: 0.9; padding: 30px 40px; display: flex; flex-direction: column; gap: 20px;
    background-image:
      linear-gradient(rgba(0,0,0,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,0,0,0.03) 1px, transparent 1px);
    background-size: 20px 20px;
  }

