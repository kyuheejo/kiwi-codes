    }
    .sticker { width: 40px; height: 40px; }
    .package-container { flex-direction: column; border-radius: 24px; height: auto; }
    .panel-front { border-right: none; border-bottom: 4px dashed rgba(42,31,26,0.3); padding: 30px 20px; }
    .panel-front::before, .panel-front::after { display: none; }
    .panel-back { padding: 30px 20px; }
