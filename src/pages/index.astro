  /* ==================== SCROLL REVEAL ==================== */
  .reveal {
    opacity: 0;
    transform: translateY(60px);
    transition: opacity 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Staggered children within sections */
  .reveal-child {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.5s ease, transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .reveal-child.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Slide-in variants */
  .reveal-left {
    opacity: 0;
    transform: translateX(-60px);
    transition: opacity 0.6s ease, transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .reveal-left.visible {
    opacity: 1;
    transform: translateX(0);
  }

  .reveal-right {
    opacity: 0;
    transform: translateX(60px);
    transition: opacity 0.6s ease, transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .reveal-right.visible {
    opacity: 1;
    transform: translateX(0);
  }

  /* Scale-up variant for cards */
  .reveal-scale {
    opacity: 0;
    transform: scale(0.85);
    transition: opacity 0.5s ease, transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .reveal-scale.visible {
    opacity: 1;
    transform: scale(1);
  }

