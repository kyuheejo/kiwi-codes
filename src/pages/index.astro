  .footer-inner { max-width: 600px; margin: 0 auto; }
  .footer-logo { font-family: var(--font-logo); font-size: 28px; color: var(--kiwi-light); margin-bottom: 8px; }
  .site-footer p { color: rgba(255,255,255,0.6); font-size: 14px; margin-bottom: 16px; }
  .footer-links { display: flex; justify-content: center; gap: 20px; margin-bottom: 20px; }
  .footer-links a { color: rgba(255,255,255,0.7); font-family: var(--font-data); font-weight: 600; font-size: 14px; transition: color 0.2s; }
  .footer-links a:hover { color: var(--kiwi-light); }
  .footer-copy { font-size: 12px !important; color: rgba(255,255,255,0.3) !important; }

  /* ==================== TABLET ==================== */
