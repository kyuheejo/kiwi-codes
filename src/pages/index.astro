  /* ==================== BLOG ==================== */
  .section-blog {
    padding: 80px 0;
    position: relative; z-index: 10;
    scroll-margin-top: 60px;
  }
  .receipt-board {
    background-color: var(--pouch-bg); border-radius: 4px;
