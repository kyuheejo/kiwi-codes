    .remote-body { width: 100%; max-width: 340px; }
    .remote-channels { max-height: none; }
    /* Guestbook mobile */
    .gb-deli-sign { padding: 0.8rem 1.5rem; margin-bottom: 2rem; }
    .gb-deli-sign h2 { font-size: 1.5rem; }
    .gb-deli-sign-sub { font-size: 0.65rem; letter-spacing: 2px; }
    .gb-control-desk {
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 1.5rem;
      padding: 0 16px;
    }
    .gb-dispenser { display: none; }
    .gb-led-panel { padding: 1rem 1.5rem; border-width: 6px; text-align: center; }
    .gb-led-text { font-size: 2rem; }
    .gb-form-wrapper { max-width: 100%; width: 100%; }
    .gb-order-form { transform: none; }
    .gb-ticket { width: 220px; }
    .gb-chalkboard { width: 220px; font-size: 0.9rem; }
    .gb-coupon { width: 200px; }
    .gb-tickets-track { padding: 15px 1rem 3rem 1rem; gap: 1.2rem; margin-top: -25px; }
    .gb-ticket-num { font-size: 2.5rem; }
    .gb-ticket-content { padding: 1rem; gap: 0.6rem; }
  }
</style>

<script>
  // Splash → main transition (only show once per session)
  const hasSeenSplash = sessionStorage.getItem('kiwi-splash-seen');

  if (hasSeenSplash) {
    // Skip splash entirely — show main content immediately
    document.getElementById('splash')?.classList.add('hidden');
    document.getElementById('main-content')?.classList.add('main-visible');
  } else {
    // First visit — play the animation, then mark as seen
    sessionStorage.setItem('kiwi-splash-seen', 'true');
    setTimeout(() => {
      document.getElementById('splash')?.classList.add('hidden');
      document.getElementById('main-content')?.classList.add('main-visible');
    }, 1900);
  }

  // Scroll-triggered reveal animations
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target;

          // If it's a staggered child, add delay based on sibling index
          if (el.classList.contains('reveal-scale') || el.classList.contains('reveal-child')) {
            const parent = el.parentElement;
            if (parent) {
              const siblings = Array.from(parent.querySelectorAll(':scope > .reveal-scale, :scope > .reveal-child'));
              const index = siblings.indexOf(el);
              el.style.transitionDelay = `${index * 0.12}s`;
            }
          }

          el.classList.add('visible');
          revealObserver.unobserve(el);
        }
      });
    },
    { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
  );

  // Observe all reveal elements after splash finishes
  setTimeout(() => {
    document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale, .reveal-child').forEach((el) => {
      // Skip elements that are already in the hero (handled by main-visible)
      if (!el.closest('.hero-section')) {
        revealObserver.observe(el);
      }
    });
  }, hasSeenSplash ? 100 : 2000);

  // ===== DELI TV CHANNEL SWITCHER =====
  (() => {
    let currentCh = 0;
    let isMuted = true;
    const chBtns = document.querySelectorAll('.ch-btn');
    const chDisplay = document.getElementById('tv-channel-display');
    const chNum = document.getElementById('remote-ch-num');
    const iframe = document.getElementById('tv-iframe');
    const tvScreen = document.getElementById('tv-screen');
    const volumeDial = document.getElementById('tv-volume-dial');
    const videoIds = JSON.parse(tvScreen?.dataset.videos || '[]');
    const total = videoIds.length;

    function getEmbedUrl(videoId) {
      return `https://www.youtube.com/embed/${videoId}?rel=0&modestbranding=1&autoplay=1&mute=${isMuted ? 1 : 0}&enablejsapi=1`;
    }

    // Canvas static noise (지지직)
    const canvas = document.getElementById('tv-static-canvas');
    const ctx = canvas?.getContext('2d');
    let staticRAF = null;

    function resizeCanvas() {
      if (!canvas) return;
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
    }
    window.addEventListener('resize', resizeCanvas);
    resizeCanvas();

    function drawStatic() {
      if (!ctx || canvas.style.opacity === '0') { staticRAF = null; return; }
      const idata = ctx.createImageData(canvas.width, canvas.height);
      const buf = new Uint32Array(idata.data.buffer);
      for (let i = 0; i < buf.length; i++) {
        const v = (Math.random() * 255) | 0;
        buf[i] = 0xff000000 | (v << 16) | (v << 8) | v;
      }
      ctx.putImageData(idata, 0, 0);
      staticRAF = requestAnimationFrame(drawStatic);
    }

    function showStatic() {
      if (!canvas) return;
      canvas.style.opacity = '1';
      if (!staticRAF) drawStatic();
    }

    function hideStatic() {
      if (!canvas) return;
      canvas.style.opacity = '0';
      if (staticRAF) { cancelAnimationFrame(staticRAF); staticRAF = null; }
    }

    function switchChannel(idx) {
      if (idx === currentCh || idx < 0 || idx >= total) return;
      currentCh = idx;

      // Show static noise + blank the iframe
      showStatic();
      if (iframe) iframe.src = '';

      // After static, load new video
      setTimeout(() => {
        if (iframe) iframe.src = getEmbedUrl(videoIds[currentCh]);
        hideStatic();
      }, 500);

      // Update channel display on screen
      const chCode = chBtns[currentCh]?.dataset.ch || '01';
      if (chDisplay) {
        chDisplay.textContent = `CH ${chCode}`;
        chDisplay.classList.remove('show');
        void chDisplay.offsetWidth;
        chDisplay.classList.add('show');
      }

      // Update remote clipboard display
      if (chNum) chNum.textContent = `CH ${chCode}`;

      // Update active button
      chBtns.forEach(b => b.classList.remove('active'));
      chBtns[currentCh]?.classList.add('active');
    }

    // Channel button clicks
    chBtns.forEach((btn, i) => {
      btn.addEventListener('click', () => switchChannel(i));
    });

    // Arrow navigation (PREV / NEXT)
    document.getElementById('ch-up')?.addEventListener('click', () => {
      switchChannel((currentCh - 1 + total) % total);
    });
    document.getElementById('ch-down')?.addEventListener('click', () => {
      switchChannel((currentCh + 1) % total);
    });

    // Autoplay on scroll into view
    if (iframe && tvScreen) {
      let tvStarted = false;
      const tvObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !tvStarted) {
            tvStarted = true;
            iframe.src = getEmbedUrl(videoIds[0]);
            tvObserver.disconnect();
          }
        });
      }, { threshold: 0.3 });
      tvObserver.observe(tvScreen);
    }

    // Volume dial toggle — uses YouTube postMessage API (no reload)
    if (volumeDial && iframe) {
      volumeDial.addEventListener('click', () => {
        isMuted = !isMuted;
        volumeDial.classList.toggle('muted', isMuted);
        volumeDial.classList.toggle('unmuted', !isMuted);
        iframe.contentWindow?.postMessage(JSON.stringify({
          event: 'command',
          func: isMuted ? 'mute' : 'unMute'
        }), '*');
      });
    }
  })();

  // ===== GUESTBOOK / DELI COUNTER =====
  (() => {
    const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
    const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
    const board = document.getElementById('ticket-board');
    const sentinel = document.getElementById('ticket-sentinel');
    const form = document.getElementById('guestbook-form') as HTMLFormElement | null;
    const statusEl = document.getElementById('form-status');
    const submitBtn = document.getElementById('gb-submit-btn') as HTMLButtonElement | null;
    const nowServingEl = document.getElementById('now-serving-num');
    const dispenserNumEl = document.getElementById('dispenser-next-num');
    const charCountEl = document.getElementById('char-count');
    const rackSystem = document.querySelector('.gb-rack-system');
    const promos = JSON.parse(rackSystem?.getAttribute('data-promos') || '[]');
    const RATE_LIMIT_MS = 5 * 60 * 1000;
    const PROMO_POSITIONS = [3, 7, 13];
    const PAGE_SIZE = 20;

    // Pagination state
    let allTickets: any[] = [];
    let isLoadingMore = false;
    let hasMoreTickets = true;
    let lastTicketNumber: number | null = null;
    let promoIdx = 0;

    // Basic profanity filter
    const BLOCKED_WORDS = [
      'fuck', 'shit', 'damn', 'ass', 'bitch', 'dick', 'crap',
      'bastard', 'hell', 'piss', 'whore', 'slut',
      '시발', '씨발', '개새끼', '병신', '지랄', '닥쳐', '꺼져',
    ];

    function containsProfanity(text: string): boolean {
      const lower = text.toLowerCase();
      return BLOCKED_WORDS.some(w => lower.includes(w));
    }

    function formatDate(dateStr: string): string {
      const d = new Date(dateStr);
      const now = new Date();
      const diffMs = now.getTime() - d.getTime();
      const diffMin = Math.floor(diffMs / 60000);
      if (diffMin < 5) return 'JUST NOW';
      if (diffMin < 60) return `${diffMin}m AGO`;
      return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }).toUpperCase();
    }

    function escapeHtml(str: string): string {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    function randomSwayStyle(): string {
      const dur = (5 + Math.random() * 4).toFixed(1);
      const delay = (Math.random() * -8).toFixed(1);
      return `animation-duration: ${dur}s; animation-delay: ${delay}s;`;
    }

    // Create a ticket wrapper with clip
    function createWrapper(innerEl: HTMLElement, isNew = false): HTMLElement {
      const wrapper = document.createElement('div');
      wrapper.className = `gb-ticket-wrapper${isNew ? ' gb-ticket-new' : ''}`;
      wrapper.setAttribute('style', randomSwayStyle());
      wrapper.innerHTML = '<div class="gb-metal-clip"></div>';
      wrapper.appendChild(innerEl);
      return wrapper;
    }

    // Rich ticket card
    function createTicketEl(ticket: { ticket_number: number; name: string; message: string; created_at: string }, isNew = false): HTMLElement {
      const num = String(ticket.ticket_number).padStart(3, '0');
      const el = document.createElement('div');
      el.className = 'gb-ticket';
      el.innerHTML = `
        <div class="gb-ticket-perf"></div>
        <div class="gb-ticket-content">
          <div class="gb-ticket-num-header">
            <span class="gb-ticket-label-sm">Ticket No.</span>
            <div class="gb-ticket-num">${num}</div>
          </div>
          <div class="gb-data-row">
            <span class="gb-data-label">NAME</span>
            <span class="gb-data-leader"></span>
            <span class="gb-data-value">${escapeHtml(ticket.name).toUpperCase()}</span>
          </div>
          <div class="gb-ticket-msg">
            "${escapeHtml(ticket.message)}"
            <div class="gb-stamp-date">${formatDate(ticket.created_at)}</div>
          </div>
        </div>
        <div class="gb-ticket-perf bottom"></div>
      `;
      return createWrapper(el, isNew);
    }

    // Placeholder ticket
    function createPlaceholderEl(): HTMLElement {
      const el = document.createElement('div');
      el.className = 'gb-ticket gb-ticket-placeholder';
      el.innerHTML = `
        <div class="gb-ticket-perf"></div>
        <div class="gb-ticket-content">
          <div class="gb-ticket-num-header">
            <span class="gb-ticket-label-sm">Ticket No.</span>
            <div class="gb-ticket-num">001</div>
          </div>
          <div class="gb-data-row">
            <span class="gb-data-label">NAME</span>
            <span class="gb-data-leader"></span>
            <span class="gb-data-value">YOU?</span>
          </div>
          <div class="gb-ticket-msg">
            "Be the first to leave a note!"
          </div>
        </div>
        <div class="gb-ticket-perf bottom"></div>
      `;
      return createWrapper(el);
    }

    // Chalkboard promo
    function createChalkboardEl(promo: any): HTMLElement {
      const el = document.createElement('div');
      el.className = 'gb-chalkboard';
      el.innerHTML = `
        <div class="gb-chalk-header">${escapeHtml(promo.title)}</div>
        <div class="gb-chalk-text">${escapeHtml(promo.content)}</div>
        <div class="gb-chalk-footer">${escapeHtml(promo.badge || '')}</div>
      `;
      return createWrapper(el);
    }

    // Coupon promo
    function createCouponEl(promo: any): HTMLElement {
      const el = document.createElement('div');
      el.className = 'gb-coupon';
      el.innerHTML = `
        <div class="gb-coupon-scissor">&zwj;</div>
        <div class="gb-coupon-cutline"></div>
        <div class="gb-coupon-title">${escapeHtml(promo.title)}</div>
        <div class="gb-coupon-desc">${escapeHtml(promo.content)}</div>
        ${promo.code ? `<div class="gb-coupon-code">CODE: ${escapeHtml(promo.code)}</div>` : ''}
        <div class="gb-barcode"></div>
        <div class="gb-barcode-num">${escapeHtml(promo.detail || '8 675309 0042 1')}</div>
      `;
      return createWrapper(el);
    }

    function createPromoEl(promo: any): HTMLElement {
      return promo.type === 'chalkboard' ? createChalkboardEl(promo) : createCouponEl(promo);
    }

    function updateNowServing(num: number) {
      const str = String(num).padStart(3, '0');
      if (nowServingEl) nowServingEl.textContent = str;
      if (dispenserNumEl) dispenserNumEl.textContent = String(num + 1).padStart(3, '0');
    }

    // Insert element before sentinel
    function insertBeforeSentinel(el: HTMLElement) {
      if (board && sentinel) {
        board.insertBefore(el, sentinel);
      }
    }

    // Append tickets with promo insertion
    function appendTickets(tickets: any[]) {
      tickets.forEach((ticket) => {
        allTickets.push(ticket);
        insertBeforeSentinel(createTicketEl(ticket));

        // Check if we should insert a promo after this global index
        const globalIdx = allTickets.length;
        if (PROMO_POSITIONS.includes(globalIdx) && promoIdx < promos.length) {
          insertBeforeSentinel(createPromoEl(promos[promoIdx++]));
        }
      });

      // If no more tickets to load, append remaining promos
      if (!hasMoreTickets) {
        while (promoIdx < promos.length) {
          insertBeforeSentinel(createPromoEl(promos[promoIdx++]));
        }
      }
    }

    // Initial render for empty state
    function renderEmpty() {
      if (!board) return;
      // Clear everything except sentinel
      const children = Array.from(board.children);
      children.forEach(c => { if (c !== sentinel) c.remove(); });
      insertBeforeSentinel(createPlaceholderEl());
      promos.forEach((p: any) => insertBeforeSentinel(createPromoEl(p)));
      promoIdx = promos.length;
    }

    function setStatus(msg: string, type: 'success' | 'error' | '') {
      if (!statusEl) return;
      statusEl.textContent = msg;
      statusEl.className = `form-status ${type}`;
    }

    function isRateLimited(): boolean {
      const last = localStorage.getItem('kiwi-last-ticket');
      if (!last) return false;
      return Date.now() - parseInt(last, 10) < RATE_LIMIT_MS;
    }

    // Char counter
    const textarea = form?.querySelector('textarea');
    textarea?.addEventListener('input', () => {
      if (charCountEl) charCountEl.textContent = String(textarea.value.length);
    });

    // Skip Supabase if not configured
    if (!SUPABASE_URL || !SUPABASE_KEY || SUPABASE_URL.includes('YOUR_PROJECT')) {
      renderEmpty();
      form?.addEventListener('submit', (e) => {
        e.preventDefault();
        setStatus('Kitchen is closed — backend not configured yet!', 'error');
      });
      return;
    }

    // Dynamic Supabase mode
    let supabase: any = null;
    let sentinelObserver: IntersectionObserver | null = null;

    async function initSupabase() {
      const { createClient } = await import('@supabase/supabase-js');
      supabase = createClient(SUPABASE_URL, SUPABASE_KEY);
    }

    async function loadTickets(cursor?: number) {
      if (!supabase || isLoadingMore) return;
      isLoadingMore = true;

      // Show loading indicator
      let loadingEl: HTMLElement | null = null;
      if (cursor) {
        loadingEl = document.createElement('div');
        loadingEl.className = 'gb-loading-more';
        loadingEl.textContent = 'LOADING...';
        insertBeforeSentinel(loadingEl);
      }

      try {
        let query = supabase
          .from('guestbook_tickets')
          .select('*')
          .eq('approved', true)
          .order('ticket_number', { ascending: false })
          .limit(PAGE_SIZE);

        if (cursor) {
          query = query.lt('ticket_number', cursor);
        }

        const { data, error } = await query;
        if (error) throw error;

        const tickets = data || [];
        hasMoreTickets = tickets.length === PAGE_SIZE;

        if (tickets.length > 0) {
          lastTicketNumber = tickets[tickets.length - 1].ticket_number;
        }

        // Remove loading indicator
        if (loadingEl) loadingEl.remove();

        if (!cursor) {
          // First load
          if (tickets.length === 0) {
            renderEmpty();
          } else {
            updateNowServing(tickets[0].ticket_number);
            appendTickets(tickets);
            startSentinelObserver();
          }
        } else {
          // Subsequent loads
          appendTickets(tickets);
        }
      } catch (err) {
        console.error('Failed to load tickets:', err);
        if (loadingEl) loadingEl.remove();
      } finally {
        isLoadingMore = false;
      }
    }

    function startSentinelObserver() {
      if (!sentinel || !board) return;
      const trackEl = document.querySelector('.gb-tickets-track');
      sentinelObserver = new IntersectionObserver((entries) => {
        if (entries[0]?.isIntersecting && !isLoadingMore && hasMoreTickets && lastTicketNumber) {
          loadTickets(lastTicketNumber);
        }
      }, { root: trackEl, rootMargin: '0px 400px 0px 0px' });
      sentinelObserver.observe(sentinel);
    }

    // Load on scroll into view
    const gbSection = document.getElementById('guestbook');
    if (gbSection) {
      let gbLoaded = false;
      const gbObserver = new IntersectionObserver(async (entries) => {
        if (entries[0]?.isIntersecting && !gbLoaded) {
          gbLoaded = true;
          await initSupabase();
          await loadTickets();
          gbObserver.disconnect();
          // Start auto-scroll now that tickets are rendered
          window.dispatchEvent(new CustomEvent('guestbook-loaded'));
        }
      }, { threshold: 0.1 });
      gbObserver.observe(gbSection);
    }

    // Form submission
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!supabase) {
        setStatus('Still loading, try again...', 'error');
        return;
      }

      const formData = new FormData(form);
      const name = (formData.get('name') as string || '').trim();
      const message = (formData.get('message') as string || '').trim();

      if (!name || !message) {
        setStatus('Please fill in both fields', 'error');
        return;
      }

      if (name.length > 30 || message.length > 200) {
        setStatus('Name or message too long', 'error');
        return;
      }

      if (containsProfanity(name) || containsProfanity(message)) {
        setStatus('Keep it friendly, please!', 'error');
        return;
      }

      if (isRateLimited()) {
        setStatus('One ticket per 5 minutes — come back soon!', 'error');
        return;
      }

      if (submitBtn) submitBtn.disabled = true;
      setStatus('Printing your ticket...', '');

      try {
        const { data, error } = await supabase
          .from('guestbook_tickets')
          .insert({ name, message })
          .select()
          .single();

        if (error) throw error;

        localStorage.setItem('kiwi-last-ticket', String(Date.now()));
        setStatus('Order submitted! Your ticket is on the rail.', 'success');
        form.reset();
        if (charCountEl) charCountEl.textContent = '0';

        if (board && data) {
          // Remove placeholder if exists
          board.querySelector('.gb-ticket-placeholder')?.closest('.gb-ticket-wrapper')?.remove();
          const ticketEl = createTicketEl(data, true);
          const firstWrapper = board.querySelector('.gb-ticket-wrapper');
          if (firstWrapper) {
            board.insertBefore(ticketEl, firstWrapper);
          } else {
            insertBeforeSentinel(ticketEl);
          }
          allTickets.unshift(data);
          updateNowServing(data.ticket_number);

          // Start sentinel observer if this is the first ticket
          if (!sentinelObserver) startSentinelObserver();
        }
      } catch (err) {
        console.error('Failed to submit ticket:', err);
        setStatus('Something went wrong — try again!', 'error');
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });

    // Auto-scroll the ticket rack when guestbook is in view
    const trackEl2 = document.querySelector('.gb-tickets-track') as HTMLElement | null;
    if (trackEl2 && gbSection) {
      let autoScrollId: number | null = null;
      let userInteracted = false;
      let resumeTimeout: ReturnType<typeof setTimeout> | null = null;
      const SPEED = 0.5; // px per frame

      let scrollAccumulator = 0;

      function startAutoScroll() {
        if (autoScrollId) return;
        scrollAccumulator = 0;
        autoScrollId = requestAnimationFrame(function tick() {
          if (!trackEl2 || userInteracted) {
            autoScrollId = null;
            return;
          }
          scrollAccumulator += SPEED;
          if (scrollAccumulator >= 1) {
            const px = Math.floor(scrollAccumulator);
            trackEl2.scrollLeft += px;
            scrollAccumulator -= px;
          }
          // Stop if near the end
          if (trackEl2.scrollLeft >= trackEl2.scrollWidth - trackEl2.clientWidth - 2) {
            autoScrollId = null;
            return;
          }
          autoScrollId = requestAnimationFrame(tick);
        });
      }

      function stopAutoScroll() {
        if (autoScrollId) {
          cancelAnimationFrame(autoScrollId);
          autoScrollId = null;
        }
      }

      function pauseAndResume() {
        userInteracted = true;
        stopAutoScroll();
        if (resumeTimeout) clearTimeout(resumeTimeout);
        resumeTimeout = setTimeout(() => {
          userInteracted = false;
          startAutoScroll();
        }, 4000); // resume after 4s of no interaction
      }

      // Pause on user interaction
      trackEl2.addEventListener('pointerdown', pauseAndResume);
      trackEl2.addEventListener('wheel', pauseAndResume, { passive: true });
      trackEl2.addEventListener('touchstart', pauseAndResume, { passive: true });

      // Start/stop based on visibility, but only after tickets are loaded
      let ticketsLoaded = false;

      function setupVisibilityObserver() {
        const scrollObserver = new IntersectionObserver((entries) => {
          if (entries[0]?.isIntersecting) {
            if (!userInteracted) startAutoScroll();
          } else {
            stopAutoScroll();
          }
        }, { threshold: 0.2 });
        scrollObserver.observe(gbSection!);
      }

      window.addEventListener('guestbook-loaded', () => {
        ticketsLoaded = true;
        setupVisibilityObserver();
        // Start immediately if already in view
        if (!userInteracted) startAutoScroll();
      });
    }
  })();

  // ===== MOBILE SHELF SWIPE CAROUSEL =====
  (() => {
    const shelf = document.getElementById('mobile-shelf');
    const dots = document.querySelectorAll('.shelf-dot');
    const priceTag = shelf?.closest('.shelf-mobile')?.querySelector('.mobile-price-tag');
    if (!shelf || !priceTag) return;

    const messages = [
      'PRICED TO HIRE: $0.00',
      'OFFLINE AI POWERED',
      'OPEN SOURCE FREE',
      'HACKATHON WINNER',
      'PREMIUM QUALITY',
    ];

    let currentIndex = 0;

    function updateCarousel() {
      const pouches = shelf.querySelectorAll('.pouch');
      if (!pouches.length) return;

      const scrollLeft = shelf.scrollLeft;
      const cardWidth = pouches[0].offsetWidth + 16; // gap
      const newIndex = Math.round(scrollLeft / cardWidth);
      const clampedIndex = Math.max(0, Math.min(newIndex, pouches.length - 1));

      if (clampedIndex !== currentIndex) {
        currentIndex = clampedIndex;
        priceTag.textContent = messages[currentIndex] || messages[0];
        dots.forEach((d, i) => d.classList.toggle('active', i === currentIndex));
      }
    }

    shelf.addEventListener('scroll', updateCarousel, { passive: true });

    // Dot click to scroll
    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const idx = parseInt(dot.dataset.index, 10);
        const pouches = shelf.querySelectorAll('.pouch');
        if (!pouches[idx]) return;
        const cardWidth = pouches[0].offsetWidth + 16;
        shelf.scrollTo({ left: cardWidth * idx, behavior: 'smooth' });
      });
    });
  })();

</script>
