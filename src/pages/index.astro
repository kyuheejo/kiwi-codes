    color: #888;
    letter-spacing: 2px;
  }

  /* Ticket entry animation */
  @keyframes ticketDrop {
    from { opacity: 0; transform: translateY(-30px) scale(0.8); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  .gb-ticket-new {
    animation: ticketDrop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  /* Placeholder ticket styling */
  .gb-ticket-placeholder .gb-ticket-msg {
    border-style: dashed;
